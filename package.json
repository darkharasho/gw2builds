{
  "name": "gw2builds-desktop",
  "version": "0.1.0",
  "description": "GW2 build editor desktop app with GitHub Pages publishing",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && APP_PROFILE=dev VITE_DEV_SERVER_URL=http://localhost:5173 electronmon .\"",
    "dev:clean": "node scripts/dev-clean.mjs",
    "build:renderer": "vite build",
    "seed": "node lib/gw2-balance-splits/scripts/seed.js",
    "crawl": "node lib/gw2-balance-splits/scripts/crawl-patches.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {
      "^.+/src/renderer/.+\\.js$": [
        "babel-jest",
        {}
      ]
    },
    "transformIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "src/main/**/*.js",
      "!src/main/index.js",
      "src/renderer/modules/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testTimeout": 15000,
    "clearMocks": true
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.3",
    "electron": "^37.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.3.0",
    "cheerio": "^1.2.0",
    "concurrently": "^9.2.1",
    "electronmon": "^2.0.3",
    "jest": "^30.3.0",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5"
  }
}
