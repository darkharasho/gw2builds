{
  "name": "gw2-buildsite-desktop",
  "version": "0.1.0",
  "description": "Electron wrapper for pyrogw2/buildsite with GitHub sync and publish",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electronmon .\"",
    "build:renderer": "vite build"
  },
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "dotenv": "^17.2.3",
    "electron": "^37.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electronmon": "^2.0.3",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5"
  }
}
